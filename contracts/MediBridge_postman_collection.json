              ]
            }
          }
        },
        {
          "name": "Get AI analysis for a document",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ai/analysis/{{doc_delivered_id}}",
              "host": [
                "{{base_url}}"
              ],
