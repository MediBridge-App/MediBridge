                "{{doc_delivered_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Organizations",
      "item": [
        {
          "name": "Get all organizations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/organizations",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "organizations"
              ]
            }
          }
        },
        {
          "name": "Get organization by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/organizations/{{org_stmercy_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "organizations",
                "{{org_stmercy_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get org users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users"
              ]
            }
          }
        },
        {
          "name": "Update user role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"organization_admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{user_maria_id}}/role",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "{{user_maria_id}}",
                "role"
              ]
            }
          }
        },
        {
          "name": "Update user status (activate/deactivate)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{user_maria_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "{{user_maria_id}}",
                "status"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Error Handling & Edge Cases",
      "item": [
        {
          "name": "Get inbox filtered by status=rejected",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents/inbox?status=rejected",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "inbox"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "rejected"
                }
              ]
            }
          }
        },
        {
          "name": "Get inbox filtered by status=ocr_failed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents/inbox?status=ocr_failed",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "inbox"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "ocr_failed"
                }
              ]
            }
          }
        },
        {
          "name": "Get rejected document by ID (TX-1011)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents/{{doc_rejected_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "{{doc_rejected_id}}"
              ]
            }
          }
        },
        {
          "name": "Get OCR-failed document by ID (TX-1012)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents/{{doc_ocr_failed_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "{{doc_ocr_failed_id}}"
              ]
            }
          }
        },
        {
          "name": "Attempt unauthorized access to routed document (TX-1013, expect 403)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents/{{doc_permission_denied_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "{{doc_permission_denied_id}}"
              ]
            }
          },
          "description": "Run this while authenticated as user_stmercy_physician_id (an org not granted document_access to TX-1013). Expected: 403 Forbidden, and a new auth_failure row should appear in audit_logs."
        },
        {
          "name": "Get audit event (document_rejected)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/audit/{{audit_event_rejected_id}}",
